# Application
APP_NAME=AI Customer Support Platform
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/support_platform
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# AI Configuration
OPENAI_API_KEY=your-openai-api-key
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=2000

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Email (for escalation notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@company.com
SMTP_PASSWORD=your-app-password

# SLA Configuration (in hours)
SLA_LOW_PRIORITY_HOURS=48
SLA_MEDIUM_PRIORITY_HOURS=24
SLA_HIGH_PRIORITY_HOURS=8
SLA_CRITICAL_PRIORITY_HOURS=2

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
